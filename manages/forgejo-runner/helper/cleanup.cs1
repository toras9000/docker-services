#!/usr/bin/env -S dotnet run --file
#:package Lestaly.General@0.124.0
using Lestaly;

var settings = new
{
    ServiceConfigDir = ThisSource.RelativeDirectory("../assets/services"),
};

return await Paved.ProceedAsync(noPause: args.RoughContains("--no-pause"), async () =>
{
    settings.ServiceConfigDir.DeleteRecurse();
});
